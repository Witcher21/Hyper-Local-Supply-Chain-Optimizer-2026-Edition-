# Frontend (.env at project root, loaded by Vite)

# Mapbox public token — get one free at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Backend API host (no protocol)
VITE_API_HOST=localhost:8000

# Demo business credentials (match backend/init.sql seed)
VITE_BUSINESS_ID=1
VITE_API_KEY=demo-key
