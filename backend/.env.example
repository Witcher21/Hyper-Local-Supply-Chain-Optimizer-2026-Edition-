# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/supply_chain

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:9000,http://localhost:3000

# External APIs (Phase 2)
MAPBOX_API_KEY=pk.your_mapbox_public_token
OPENWEATHER_API_KEY=your_openweather_key
OPENAI_API_KEY=sk-your_openai_key
